---
import "@/styles/global.css";

import type { Thing, WithContext } from "schema-dts";

import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import Seo from "@/components/shared/Seo.astro";
import { navigationLinks } from "@/config/navigation";
import { siteConfig } from "@/config/site";
import { getLocalBusinessSchema } from "@/lib/schema";

type StructuredData = WithContext<Thing>;

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  type?: "website" | "article";
  structuredData?: StructuredData | StructuredData[];
  hideHeader?: boolean;
  hideFooter?: boolean;
  bodyClass?: string;
}

const {
  title,
  description,
  canonical,
  image,
  imageAlt,
  noindex,
  type,
  structuredData,
  hideHeader = false,
  hideFooter = false,
  bodyClass = "",
} = Astro.props;

const localBusinessSchema = getLocalBusinessSchema(Astro.site);
let schema: StructuredData[] = [localBusinessSchema];

if (Array.isArray(structuredData)) {
  schema = [localBusinessSchema, ...structuredData];
} else if (structuredData) {
  schema = [localBusinessSchema, structuredData];
}
---

<!doctype html>
<html lang={siteConfig.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={siteConfig.seo.themeColor} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <Seo
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      imageAlt={imageAlt}
      noindex={noindex}
      type={type}
      structuredData={schema}
    />
  </head>
  <body class:list={["min-h-dvh", bodyClass]}>
    <a
      class="bg-background text-foreground sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-md focus:px-4 focus:py-2 focus:shadow-md"
      href="#main-content"
    >
      Skip to content
    </a>
    <div class="flex min-h-dvh flex-col">
      {!hideHeader && <Header navItems={navigationLinks} />}
      <main id="main-content" class="flex-1">
        <slot />
      </main>
      {!hideFooter && <Footer />}
    </div>
  </body>
</html>
