---
import Section from "@/components/shared/Section.astro";
import { getPublishedFaqs } from "@/features/faq/content";
import FaqAccordion from "@/features/faq/FaqAccordion";
import StandardPageLayout from "@/layouts/StandardPageLayout.astro";
import { getBreadcrumbSchema, getFAQPageSchema } from "@/lib/schema";

const faqs = await getPublishedFaqs();
const items = faqs.map((faq) => ({
  id: faq.id,
  question: faq.data.question,
  answer: faq.data.answer,
}));
const structuredData = [
  getFAQPageSchema(items.map(({ question, answer }) => ({ question, answer }))),
  getBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "FAQ", path: "/faq" },
  ]),
];
---

<StandardPageLayout
  eyebrow="FAQ"
  title="Frequently asked questions"
  description="Common questions about our services."
  structuredData={structuredData}
>
  <Section tone="surface">
    <FaqAccordion client:visible items={items} />
  </Section>
</StandardPageLayout>
