---
import {
  CalendarCheckIcon,
  ClipboardListIcon,
  MapPinIcon,
  PhoneIcon,
  ThumbsUpIcon,
} from "lucide-react";

import Section from "@/components/shared/Section.astro";
import { buttonVariants } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { siteConfig } from "@/config/site";
import { getPublishedProjects } from "@/features/projects/content";
import { getFeaturedServices } from "@/features/services/content";
import { serviceIconMap } from "@/features/services/icons";
import { getPublishedTestimonials } from "@/features/testimonials/content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const featuredServices = await getFeaturedServices();
const testimonials = (await getPublishedTestimonials()).filter(
  (t) => t.data.featured,
);
const featuredProjects = (await getPublishedProjects())
  .filter((p) => p.data.featured)
  .slice(0, 3);

const trustPoints = [
  "Free estimates",
  "Licensed & insured",
  "No long-term contracts",
  "Same-day-of-week service",
];

const steps = [
  {
    icon: PhoneIcon,
    title: "Request an estimate",
    description:
      "Call or send the contact form. Most quotes go out within 24 hours — simple mowing quotes often the same day.",
  },
  {
    icon: ClipboardListIcon,
    title: "Get a clear plan",
    description:
      "You get a written scope and price before we start. No surprises on the invoice, no work you didn't ask for.",
  },
  {
    icon: CalendarCheckIcon,
    title: "We show up — every time",
    description:
      "Same crew, same day each week. If weather pushes us back, you'll know before we're late.",
  },
];

function starRating(rating: number) {
  const full = "★";
  const empty = "☆";
  return full.repeat(rating) + empty.repeat(5 - rating);
}

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "long",
  year: "numeric",
});
---

<BaseLayout
  title={siteConfig.business.name}
  description={siteConfig.seo.description}
>
  <section class="bg-primary text-primary-foreground">
    <div
      class="site-container grid gap-10 py-12 sm:py-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:py-20"
    >
      <div class="reveal-up">
        <p
          class="text-primary-foreground/80 text-sm font-semibold tracking-normal uppercase"
        >
          {siteConfig.business.tagline}
        </p>
        <h1
          class="mt-4 max-w-3xl text-4xl font-semibold tracking-normal sm:text-5xl lg:text-6xl"
        >
          {siteConfig.business.name}
        </h1>
        <p class="text-primary-foreground/80 mt-5 max-w-2xl text-lg/8">
          {siteConfig.business.description}
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            class:list={buttonVariants({ size: "lg", variant: "secondary" })}
            href={siteConfig.primaryCta.href}
          >
            {siteConfig.primaryCta.label}
          </a>
          <a
            class:list={buttonVariants({
              variant: "outline",
              size: "lg",
              className:
                "text-primary-foreground border-white/25 bg-white/10 hover:bg-white/15",
            })}
            href={siteConfig.business.phoneHref}
          >
            {siteConfig.business.phone}
          </a>
        </div>
        <ul
          class="text-primary-foreground/80 mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm"
        >
          {
            trustPoints.map((point) => (
              <li class="flex items-center gap-2">
                <ThumbsUpIcon className="size-4" aria-hidden="true" />
                {point}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="fade-in">
        <div class="rounded-lg bg-white/10 p-3 shadow-sm ring-1 ring-white/15">
          <img
            class="aspect-4/3 w-full rounded-md object-cover"
            src="/images/hero.webp"
            alt="Freshly mowed lawn with crisp stripes in front of a well-kept home"
            width="1536"
            height="1024"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <Section
    tone="surface"
    eyebrow="Services"
    title="What we offer"
    description="Everything your lawn needs through the season — from a single crew that knows your property."
  >
    <div class="grid gap-4 md:grid-cols-2">
      {
        featuredServices.map((service) => {
          const Icon = service.data.icon
            ? serviceIconMap[service.data.icon]
            : undefined;
          return (
            <Card>
              <CardHeader>
                <CardTitle className="flex items-center gap-2">
                  {Icon && (
                    <Icon className="text-primary size-5" aria-hidden="true" />
                  )}
                  {service.data.title}
                </CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground text-sm/6">
                  {service.data.summary ?? service.data.description}
                </p>
                <a
                  class="text-primary mt-5 inline-flex text-sm font-medium hover:underline"
                  href={`/services/${service.id}`}
                >
                  View service &rarr;
                </a>
              </CardContent>
            </Card>
          );
        })
      }
    </div>
    <p class="text-muted-foreground mt-6 text-sm">
      Also available: hedge & shrub trimming, mulch & bed care, and more.
      <a class="text-primary font-medium hover:underline" href="/services">
        See all services &rarr;
      </a>
    </p>
  </Section>

  <Section
    eyebrow="How it works"
    title="From first call to first mow"
    description="Working with us is deliberately simple."
  >
    <ol class="grid gap-4 md:grid-cols-3">
      {
        steps.map((step, index) => (
          <li class="bg-card rounded-lg border p-6 shadow-xs">
            <div class="flex items-center gap-3">
              <span
                class="bg-primary/10 text-primary flex size-10 items-center justify-center rounded-full"
                aria-hidden="true"
              >
                <step.icon className="size-5" />
              </span>
              <span class="text-muted-foreground text-sm font-semibold">
                Step {index + 1}
              </span>
            </div>
            <h3 class="mt-4 text-base font-semibold">{step.title}</h3>
            <p class="text-muted-foreground mt-2 text-sm/6">
              {step.description}
            </p>
          </li>
        ))
      }
    </ol>
  </Section>

  {
    featuredProjects.length > 0 && (
      <Section
        tone="surface"
        eyebrow="Recent work"
        title="Projects we're proud of"
        description="A few recent transformations from around the Springfield area."
      >
        <div class="grid gap-4 md:grid-cols-3">
          {featuredProjects.map((project) => (
            <Card>
              {project.data.image && (
                <img
                  class="aspect-video w-full rounded-t-lg object-cover"
                  src={project.data.image}
                  alt={project.data.imageAlt ?? ""}
                  width="1200"
                  height="800"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <CardHeader>
                <CardTitle className="text-base">
                  {project.data.title}
                </CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground flex items-center gap-1.5 text-xs">
                  <MapPinIcon className="size-3.5" aria-hidden="true" />
                  {project.data.location}
                  {project.data.completedAt
                    ? ` · ${dateFormatter.format(project.data.completedAt)}`
                    : ""}
                </p>
                <p class="text-muted-foreground mt-3 text-sm/6">
                  {project.data.description}
                </p>
                <a
                  class="text-primary mt-5 inline-flex text-sm font-medium hover:underline"
                  href={`/projects/${project.id}`}
                >
                  View project &rarr;
                </a>
              </CardContent>
            </Card>
          ))}
        </div>
      </Section>
    )
  }

  {
    testimonials.length > 0 && (
      <Section
        tone="tint"
        eyebrow="Testimonials"
        title="What our customers say"
      >
        <div class="grid gap-4 md:grid-cols-2">
          {testimonials.map((t) => (
            <Card>
              <CardContent className="pt-6">
                <p
                  class="text-accent text-lg"
                  aria-label={`${t.data.rating} out of 5 stars`}
                >
                  {starRating(t.data.rating)}
                </p>
                <blockquote class="text-foreground mt-3 text-base/7">
                  &ldquo;{t.data.quote}&rdquo;
                </blockquote>
                <figcaption class="text-muted-foreground mt-4 text-sm">
                  {t.data.name}
                  {t.data.location ? `, ${t.data.location}` : ""}
                </figcaption>
              </CardContent>
            </Card>
          ))}
        </div>
      </Section>
    )
  }

  <section class="bg-primary text-primary-foreground">
    <div
      class="site-container flex flex-col items-start gap-6 py-12 sm:py-16 lg:flex-row lg:items-center lg:justify-between"
    >
      <div>
        <h2 class="text-2xl font-semibold sm:text-3xl">
          Ready for a lawn you don't have to think about?
        </h2>
        <p class="text-primary-foreground/80 mt-3 max-w-2xl text-base/7">
          Get a free, no-obligation estimate. Most quotes go out within 24
          hours.
        </p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          class:list={buttonVariants({ size: "lg", variant: "secondary" })}
          href={siteConfig.primaryCta.href}
        >
          {siteConfig.primaryCta.label}
        </a>
        <a
          class:list={buttonVariants({
            variant: "outline",
            size: "lg",
            className:
              "text-primary-foreground border-white/25 bg-white/10 hover:bg-white/15",
          })}
          href={siteConfig.business.phoneHref}
        >
          {siteConfig.business.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
