---
import Section from "@/components/shared/Section.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { getPublishedServices } from "@/features/services/content";
import { serviceIconMap } from "@/features/services/icons";
import StandardPageLayout from "@/layouts/StandardPageLayout.astro";

const services = await getPublishedServices();
---

<StandardPageLayout
  eyebrow="Services"
  title="Our services"
  description="Everything your lawn and landscape need through the season, from one crew that knows your property."
>
  <Section>
    <div class="grid gap-4 md:grid-cols-2">
      {
        services.map((service, index) => {
          const Icon = service.data.icon
            ? serviceIconMap[service.data.icon]
            : undefined;
          return (
            <Card>
              {service.data.image && (
                <img
                  class="aspect-video w-full rounded-t-lg object-cover"
                  src={service.data.image}
                  alt=""
                  width="1200"
                  height="800"
                  loading={index === 0 ? "eager" : "lazy"}
                  fetchpriority={index === 0 ? "high" : "auto"}
                  decoding="async"
                />
              )}
              <CardHeader>
                <CardTitle className="flex items-center gap-2">
                  {Icon && (
                    <Icon className="text-primary size-5" aria-hidden="true" />
                  )}
                  {service.data.title}
                </CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground text-sm/6">
                  {service.data.description}
                </p>
                <a
                  class="text-primary mt-5 inline-flex text-sm font-medium hover:underline"
                  href={`/services/${service.id}`}
                >
                  Read more &rarr;
                </a>
              </CardContent>
            </Card>
          );
        })
      }
    </div>
  </Section>
</StandardPageLayout>
