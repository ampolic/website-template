---
import { buttonVariants } from "@/components/ui/button";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found" noindex>
  <section
    class="site-container grid min-h-[55vh] place-items-center py-16 text-center"
  >
    <div>
      <p class="text-primary text-sm font-semibold tracking-normal uppercase">
        404
      </p>
      <h1 class="mt-3 text-4xl font-semibold tracking-normal sm:text-5xl">
        Page not found
      </h1>
      <p class="text-muted-foreground mx-auto mt-4 max-w-lg text-base/7">
        The page you are looking for does not exist or has been moved.
      </p>
      <a
        class:list={buttonVariants({ className: "mt-7" })}
        href="/"
        data-astro-prefetch
      >
        Return Home
      </a>
    </div>
  </section>
</BaseLayout>
