---
import { buttonVariants } from "@/components/ui/button";
import MobileNav from "@/components/layout/MobileNav";
import type { NavItem } from "@/config/navigation";
import { siteConfig } from "@/config/site";

interface Props {
  navItems: NavItem[];
}

const { navItems } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isCurrentHref = (href: string) =>
  currentPath === href || currentPath.startsWith(`${href}/`);
---

<header class="bg-background/95 sticky top-0 z-40 border-b backdrop-blur">
  <div class="site-container flex h-16 items-center justify-between gap-4">
    <a class="flex min-w-0 items-center gap-3" href="/" aria-label="Home">
      <span
        class="bg-primary text-primary-foreground flex size-9 shrink-0 items-center justify-center rounded-md text-sm font-semibold"
        aria-hidden="true"
      >
        {siteConfig.business.name.slice(0, 1)}
      </span>
      <span class="truncate text-sm font-semibold sm:text-base">
        {siteConfig.business.name}
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a
            class:list={[
              "hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent rounded-md px-3 py-2 text-sm font-medium transition-colors",
              isCurrentHref(item.href)
                ? "text-foreground bg-accent"
                : "text-muted-foreground",
            ]}
            href={item.href}
            aria-current={isCurrentHref(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-2 md:flex">
      <a
        class="text-muted-foreground hover:text-foreground text-sm font-medium transition-colors"
        href={siteConfig.business.phoneHref}
        aria-label={`Call ${siteConfig.business.name} at ${siteConfig.business.phone}`}
      >
        {siteConfig.business.phone}
      </a>
      <a
        class={buttonVariants({ size: "sm" })}
        href={siteConfig.primaryCta.href}
      >
        {siteConfig.primaryCta.label}
      </a>
    </div>

    <MobileNav
      client:idle
      businessName={siteConfig.business.name}
      phone={siteConfig.business.phone}
      phoneHref={siteConfig.business.phoneHref}
      cta={siteConfig.primaryCta}
      navItems={navItems}
      currentPath={currentPath}
    />
  </div>
</header>
