---
import DesktopNav from "@/components/layout/DesktopNav";
import MobileNav from "@/components/layout/MobileNav";
import type { NavItem } from "@/config/navigation";
import { siteConfig } from "@/config/site";

interface Props {
  navItems: NavItem[];
}

const { navItems } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="bg-background/88 sticky top-0 z-40 border-b shadow-sm shadow-slate-950/5 backdrop-blur-xl"
>
  <div class="site-container flex h-16 items-center justify-between gap-4">
    <a
      class="group flex min-w-0 items-center gap-3"
      href="/"
      aria-label={`${siteConfig.business.name} - Home`}
      data-astro-prefetch
    >
      <span
        class="bg-primary text-primary-foreground ring-border/70 group-hover:ring-primary/35 flex size-10 shrink-0 items-center justify-center rounded-xl text-sm font-semibold ring-1 transition"
        aria-hidden="true"
      >
        {siteConfig.business.name.slice(0, 1)}
      </span>
      <span class="grid min-w-0 leading-none">
        <span class="truncate text-sm font-semibold sm:text-base">
          {siteConfig.business.name}
        </span>
        <span
          class="text-muted-foreground mt-1 hidden text-xs font-medium sm:block"
        >
          {siteConfig.business.taglineShort}
        </span>
      </span>
    </a>

    <div class="hidden min-w-0 shrink md:block">
      <DesktopNav client:idle navItems={navItems} currentPath={currentPath} />
    </div>

    <div class="hidden min-w-0 shrink items-center gap-3 md:flex">
      {
        siteConfig.business.phone && siteConfig.business.phoneHref && (
          <a
            class="bg-background/55 text-muted-foreground hover:bg-background/85 hover:text-foreground ring-border/70 block max-w-28 truncate rounded-full px-3.5 py-2 text-sm font-medium shadow-sm ring-1 shadow-slate-950/5 backdrop-blur transition-all hover:shadow-md hover:shadow-slate-950/10 lg:max-w-none"
            href={siteConfig.business.phoneHref}
            aria-label={`Call ${siteConfig.business.name} at ${siteConfig.business.phone}`}
            title={siteConfig.business.phone}
          >
            {siteConfig.business.phone}
          </a>
        )
      }
      <a
        class="bg-primary text-primary-foreground hover:bg-primary/90 focus-visible:bg-primary/90 shadow-primary/20 hover:shadow-primary/25 block max-w-24 truncate rounded-full px-4 py-2 text-sm font-medium shadow-sm transition-all hover:shadow-md lg:max-w-none"
        href={siteConfig.primaryCta.href}
        title={siteConfig.primaryCta.label}
        data-astro-prefetch
      >
        {siteConfig.primaryCta.label}
      </a>
    </div>

    <MobileNav
      client:idle
      businessName={siteConfig.business.name}
      phone={siteConfig.business.phone}
      phoneHref={siteConfig.business.phoneHref}
      cta={siteConfig.primaryCta}
      navItems={navItems}
      currentPath={currentPath}
    />
  </div>
</header>
