---
import BrandIcon from "@/components/shared/BrandIcon.astro";
import { navigationLinks } from "@/config/navigation";
import { siteConfig } from "@/config/site";
import { brandIcons, isBrandIconName } from "@/lib/brand-icons";

const navItems = navigationLinks;
const year = new Date().getFullYear();
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isCurrentHref = (href: string) =>
  currentPath === href || currentPath.startsWith(`${href}/`);
const socialLabels: Record<string, string> = {
  facebook: "Facebook",
  instagram: "Instagram",
  linkedin: "LinkedIn",
  x: "X",
  youtube: "YouTube",
};
const socialLinks = Object.entries(siteConfig.social).flatMap(
  ([name, href]) => {
    if (!href || !isBrandIconName(name)) return [];
    return { href, label: socialLabels[name] ?? brandIcons[name].title, name };
  },
);
---

<footer class="bg-foreground text-background">
  <div class="site-container grid gap-10 py-12 md:grid-cols-[1.5fr_1fr_1fr]">
    <div>
      <a class="text-base font-semibold" href="/">{siteConfig.business.name}</a>
      <p class="mt-3 max-w-md text-sm leading-6 opacity-70">
        {siteConfig.business.description}
      </p>
      <p class="mt-4 text-sm opacity-50">
        &copy; {year}
        {siteConfig.business.legalName}. All rights reserved.
      </p>
    </div>

    <div>
      <h2 class="text-sm font-semibold">Pages</h2>
      <nav class="mt-3 grid gap-2" aria-label="Footer navigation">
        {
          navItems.map((item) => (
            <a
              class:list={[
                "text-sm transition-colors hover:opacity-80",
                isCurrentHref(item.href) ? "opacity-100" : "opacity-60",
              ]}
              href={item.href}
              aria-current={isCurrentHref(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div>
      <h2 class="text-sm font-semibold">Contact</h2>
      <address class="mt-3 grid gap-2 text-sm not-italic opacity-60">
        <a
          class="transition-colors hover:opacity-80"
          href={siteConfig.business.phoneHref}
        >
          {siteConfig.business.phone}
        </a>
        <a
          class="transition-colors hover:opacity-80"
          href={siteConfig.business.emailHref}
        >
          {siteConfig.business.email}
        </a>
        <span>
          {siteConfig.business.address.city}, {
            siteConfig.business.address.region
          }
        </span>
      </address>
      {
        socialLinks.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-3">
            {socialLinks.map(({ href, label, name }) => (
              <a
                class="flex size-9 items-center justify-center rounded-md border border-white/20 bg-white/10 transition-colors hover:bg-white/20"
                href={href}
                aria-label={label}
                rel="noreferrer"
                target="_blank"
              >
                <BrandIcon name={name} />
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>
</footer>
