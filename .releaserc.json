{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog\n\nAll notable changes to this website are documented here.\n\nThis file is maintained by semantic-release. Use conventional commits through `npm run commit` so releases can generate accurate notes."
      }
    ],
    ["@semantic-release/npm", { "npmPublish": false }],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json", "package-lock.json"],
        "message": "chore(release): v${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "releaseBodyTemplate": "<%= nextRelease.notes.trim().replace(/^#{1,2} .+\\n\\n?/, '') %>",
        "assets": [
          {
            "path": "release-artifacts/dist.tar.gz",
            "label": "Built static site (dist.tar.gz)"
          }
        ]
      }
    ]
  ]
}
